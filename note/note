#!/bin/python
try:
    import rich, os, tempfile, argparse, sys
    from pathlib import Path
except ImportError as e:
    print(f"Import error: {e}")

class IndexOutOfBounds(Exception):
    pass

class BasicFileCheck(Exception):
    pass

class SecurityAlert(Exception):
    pass

class Note:
    def __init__(self, file_name):
        if file_name == None:
            pass
        else:
            self.base_dir = Path("~/.config/note").expanduser().resolve()
            requested_path = (self.base_dir / file_name).resolve()
            if not str(requested_path).startswith(str(self.base_dir)):
                raise SecurityAlert("Path traversal has been detected. Common don't try to hack someone  ⎛⎝( ` ᢍ ´ )⎠⎞ᵐᵘʰᵃʰᵃ")
            self.full_path = requested_path
        self.MAX_LINE = 1000
        self.MAX_INPUT = 10 * 1024 * 1024
        
        
    def check_note(self):
        if not self.full_path.exists():
            try:
                rich.print("[bold green] (+) File doesn't exists. Do you want to create a new one: [bold green]", end="")
                choice = input("y or n: ")
                if choice == "n":
                    sys.exit(0)
                self.create_a_file()
                return True
            except Exception as e:
                raise BasicFileCheck(f"Failed to re create a file: {e}")
        if not self.full_path.is_file():
            raise BasicFileCheck('File is not a file. Keep up the good work.')
        if self.full_path.is_symlink():
            raise SecurityAlert("Symbolic link has been detected. Aborting.")
        return True
       
    
    def create_a_file(self):
        try:
            self.full_path.parent.mkdir(parents=True, exist_ok=True)
            self.full_path.touch()
            return True
        except Exception as e:
            rich.print(f"[bold red] (!) Wow error here in create_a_file: {e} [bold red]")
            return False

    def write_file(self, text):
        self.check_note()
        if len(text) > self.MAX_LINE:
            raise SecurityAlert("Too high of input, Potential buffer/DDoS attack")
        if self.full_path.stat().st_size > self.MAX_INPUT:
            raise BasicFileCheck("File size limit reached.")
        with open(self.full_path, 'a') as f:
            f.write(f"{text}\n")
        return True
        
        
    def read_file(self, with_index):
        self.check_note(    )
        with open(self.full_path, "r") as f:
            for index, line in enumerate(f, 1):
                if with_index:
                    print(f'{index}. {line.rstrip('\n')}')
                else:
                    print(line.strip('\n'))
        return True
       
        
    def delete_entry(self, index):
        try:
            self.check_note()
            if index < 1:
                raise IndexOutOfBounds(f"Index {index} is out of bounds. Please enter above 0")
            fd, temp_path = tempfile.mkstemp(dir=self.base_dir, text=True) 
            with os.fdopen(fd, 'w') as tmp_file:
                with open(self.full_path, "r") as f:
                    for i, line in enumerate(f, 1):
                        if i == index:
                            continue
                        tmp_file.write(line)
            os.replace(temp_path, self.full_path)
            return True
        except IndexOutOfBounds as e:
            raise e
        except Exception as e:
            if 'temp_path' in locals() and os.path.exists(temp_path):
                os.remove(temp_path)
            raise e
        
    def append_entry(self, text, index):
        try:
            self.check_note()
            if index < 1:
                raise IndexOutOfBounds(f"Index {index} is out of bounds. Please enter above 0")
            fd, temp_path = tempfile.mkstemp(dir=self.base_dir, text=True)  
            formatted_text = f"{text}\n"
            with os.fdopen(fd, 'w') as tmp_file:
                with open(self.full_path, 'r') as f:
                    for i, line in enumerate(f, 1):
                        if i == index:
                            tmp_file.write(formatted_text)
                            continue
                        tmp_file.write(line)
            os.replace(temp_path, self.full_path)
            return True
        except IndexOutOfBounds as e:
            raise e
        except Exception as e:
            if 'temp_path' in locals() and os.path.exists(temp_path):
                os.remove(temp_path)
            raise e
        

    def insert_entry(self, text, index):
        try:
            self.check_note()
            if index < 1:
                raise IndexOutOfBounds(f"Index {index} is out of bounds. Please enter above 0")
            fd, temp_path = tempfile.mkstemp(dir=self.base_dir, text=True)  
            formatted_text = f"{text}\n"
            with os.fdopen(fd, 'w') as tmp_file:
                with open(self.full_path, 'r') as f:
                    found = False
                    for i, line in enumerate(f, 1):
                        if i == index:
                            tmp_file.write(formatted_text)
                            found = True
                        tmp_file.write(line)
                if not found and index > 1:
                    tmp_file.write(formatted_text)
            os.replace(temp_path, self.full_path)
            return True
        except IndexOutOfBounds as e:
            raise e
        except Exception as e:
            if 'temp_path' in locals() and os.path.exists(temp_path):
                os.remove(temp_path)
            raise e
        
    def search_files(self):
        try:
            files = list(self.base_dir.glob("*"))
            for file_name in files:
                print(str(file_name).split('/')[-1])
        except Exception as e:
            raise e
            
    def erase_file(self): 
        try:
            if not self.full_path.exists():
                rich.print("[bold red] (!) If you want to delete a file then create one first ദ്ദി(˵ •̀ ᴗ - ˵ ) ✧")
                return False
            self.full_path.unlink()
        except Exception as e:
            raise e
        

if __name__ == "__main__":
    try:
       
        parser = argparse.ArgumentParser(description="This is an note taking application.")
        parser.add_argument("file", nargs="?", default="note.txt", help="Enter name of note here.")
        subparsers = parser.add_subparsers(dest="command")

        list_parser = subparsers.add_parser("list", help="Lists all entries in the file")
        list_parser.add_argument("-i", "--index", action="store_true", help="Lists all entries in the file with indexes")

        add_parser = subparsers.add_parser("write", help="Writes down a entry")
        add_parser.add_argument("content", help="Write down the stuff you wanna write")

        delete_parser = subparsers.add_parser("delete", help="Deletes a entry in the list")
        delete_parser.add_argument("content", help="Write the index of the list you want to delete")

        append_parser = subparsers.add_parser("append", help="Changes the required entry")
        append_parser.add_argument("content", help="Write the content that will be kept in the entry instead")
        append_parser.add_argument("-i", "--index", help="Write the index that needs to be changed")

        insert_parser = subparsers.add_parser("insert", help="Inserts entry in the note which out removing anything else")
        insert_parser = subparsers.add_parser("content", help="Write entry to be added to the note")
        insert_parser.add_argument("-i", "--index", help="Write index that needs to be added to")

        list_parser = subparsers.add_parser("ls", help="lists all the files that has been created")
        erase_parser = subparsers.add_parser("destroy", help="Removes the file completely")

        args = parser.parse_args()  
        note = Note(args.file or None)

        if args.command == "list":
            rich.print(f'[bold yellow] (*) Listing all the entries .... (*) [bold yellow]')
            note.read_file(args.index)
        elif args.command == "write":
            rich.print(f'[bold blue] (*) Writing the content: {args.content} (*) [bold blue]')
            note.write_file(args.content)
        elif args.command == "delete":
            rich.print(f"[bold red] (*) Deleting the content: {args.content} (*) [bold red]")
            note.delete_entry(int(args.content))
        elif args.command == "append":
            rich.print(f"[bold green] (*) Appending the content: {args.content} in index {args.index} (*) [bold green]")
            note.append_entry(args.content, int(args.index))
        elif args.command == "ls":
            rich.print(f"[bold yellow] (*) Listing all the files (*) [bold yellow]")
            note.search_files()
        elif args.command == "destroy":
            rich.print(f"[bold red] (!) Are you sure you want to remove this file, [bold red]", end="")
            choice = input("y or n: ")
            if choice == "y":
                note.erase_file()
            else:
                sys.exit(0)
    except BasicFileCheck as e:
        rich.print(f'[bold red] File error: {e} [bold red]')
        sys.exit(0)
    except SecurityAlert as e:
        rich.print(f'[bold red] Security Alert: {e} [bold red]')
        sys.exit(0)
    except IndexOutOfBounds as e:
        rich.print(f'[bold red] (!) Index error: {e} [bold red]')
    except Exception as e:
        rich.print(f'[bold red] There is a huge problem, error in init: {e} [bold red]')
        sys.exit(0)